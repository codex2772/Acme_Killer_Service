# ⚠️ DO NOT COMMIT THIS FILE WITH REAL SECRETS
# Use kubectl create secret or external secrets manager (AWS Secrets Manager, etc.)
#
# Example command to create secrets:
# kubectl create secret generic jewel-erp-secret \
#   --from-literal=DATABASE_USERNAME=your-username \
#   --from-literal=DATABASE_PASSWORD=your-password \
#   --from-literal=JWT_SECRET=your-256-bit-secret-key \
#   -n jewel-erp

apiVersion: v1
kind: Secret
metadata:
  name: jewel-erp-secret
  namespace: jewel-erp
  labels:
    app: jewel-erp
type: Opaque
stringData:
  DATABASE_USERNAME: "REPLACE_ME"
  DATABASE_PASSWORD: "REPLACE_ME"
  JWT_SECRET: "REPLACE_ME_WITH_256_BIT_SECRET"
